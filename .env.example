# ─────────────────────────────────────────────
# Identus / Cloud Agent
# ─────────────────────────────────────────────

# API key for Cloud Agent (set API_KEY_ENABLED=true in docker-compose to activate)
ISSUER_API_KEY=issuer-secret-api-key-change-me
VERIFIER_API_KEY=verifier-secret-api-key-change-me

# Internal hostname used inside Docker network (do not change unless you rename services)
ISSUER_AGENT_URL=http://localhost:8000
ISSUER_DIDCOMM_URL=http://localhost:8001
VERIFIER_AGENT_URL=http://localhost:9000

# ─────────────────────────────────────────────
# Cardano — Blockfrost (preprod testnet)
# Sign up at https://blockfrost.io and create a preprod project
# ─────────────────────────────────────────────
BLOCKFROST_PROJECT_ID=preprodYourProjectIdHere

# Cardano preprod wallet for signing VC-hash metadata transactions
# Generate with: cardano-cli or any wallet lib
# Fund it with tADA from https://docs.cardano.org/cardano-testnets/tools/faucet
CARDANO_WALLET_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24"
CARDANO_NETWORK=preprod

# Cardano metadata label for VC hashes (674 is the standard CIP-0020 label for messages)
CARDANO_METADATA_LABEL=674

# ─────────────────────────────────────────────
# Application URLs (used by frontends)
# ─────────────────────────────────────────────
# Port the issuer-api backend listens on (must match VITE_ISSUER_API_URL above)
PORT=3002

VITE_ISSUER_API_URL=http://localhost:3002
VITE_VERIFIER_AGENT_URL=http://localhost:9000
VITE_MEDIATOR_OOB_URL=http://localhost:8080/invitation
VITE_CARDANOSCAN_BASE_URL=https://preprod.cardanoscan.io

# Mediator DID — populated after first run of: pnpm run health
# You must paste this value after starting the infrastructure
VITE_MEDIATOR_PEER_DID=

# University DID — populated after running: scripts/01-init-university-did.sh
VITE_UNIVERSITY_DID=
VITE_UNIVERSITY_NAME=Example University

# Diploma schema ID — populated after running: scripts/02-register-diploma-schema.sh
VITE_DIPLOMA_SCHEMA_ID=
