# ─── Infrastructure Notes ──────────────────────────────────────────────────────
#
# DEV profile  (docker-compose.dev.yml)
#   • PRISM Node runs with in-memory ledger — no Cardano node required
#   • DID publishing is simulated locally (long-form DIDs work immediately)
#   • Cardano VC hash writing uses Blockfrost directly (real preprod transactions)
#   • Ports:
#       Issuer agent REST API   → http://localhost:8000/cloud-agent
#       Verifier agent REST API → http://localhost:9000/cloud-agent
#       Mediator DIDComm        → http://localhost:8080
#       Mediator invitation     → http://localhost:8080/invitation
#
# PREPROD profile  (docker-compose.preprod.yml)
#   • PRISM Node connects to Cardano preprod via your Cardano node or Blockfrost
#   • DIDs are anchored on-chain — visible on preprod.cardanoscan.io
#   • Requires BLOCKFROST_PROJECT_ID and a funded CARDANO_WALLET_MNEMONIC
#   • See README.md Phase 1 → Step 2 for wallet funding instructions
# ──────────────────────────────────────────────────────────────────────────────

# Cloud Agent version (check https://github.com/hyperledger-identus/cloud-agent/releases)
AGENT_VERSION=2.1.0

# PRISM Node version — must be >=2.2.1 for cloud-agent >=1.9.2
# See https://github.com/hyperledger-identus/cloud-agent#compatibility-between-cloud-agent-and-prism-node
PRISM_NODE_VERSION=2.2.1

# Mediator version
MEDIATOR_VERSION=1.1.0

# Postgres password (change before any internet-exposed deployment)
POSTGRES_PASSWORD=postgres_dev_password

# Mongo password
MONGO_PASSWORD=mongo_dev_password

# ─── Blockfrost (preprod) ──────────────────────────────────────────────────────
# Create a free project at https://blockfrost.io → choose "Cardano preprod"
BLOCKFROST_PROJECT_ID=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Cardano Wallet for VC hash submission ─────────────────────────────────────
# 24-word mnemonic for the university wallet (must hold preprod tADA)
# Fund at https://docs.cardano.org/cardano-testnets/tools/faucet
CARDANO_WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24
CARDANO_NETWORK=preprod

# Issuer & Verifier agent API keys (used by issuer-portal and verifier-portal)
ISSUER_API_KEY=issuer-dev-key-change-me
VERIFIER_API_KEY=verifier-dev-key-change-me
